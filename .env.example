# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Encryption (REQUIRED) ─────────────────────────────────────────────────────
# AES-256 key: exactly 64 hex characters (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit a real key to version control.
ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Relative paths are resolved from the project root.
# On cloud platforms use an absolute path or a writable mount, e.g. /data/optimize.db
DATABASE_PATH=./db/optimize.db

# ── Public URL ────────────────────────────────────────────────────────────────
# Your deployed domain — used to build webhook callback URLs.
# e.g. https://optimize.yourdomain.com
# Leave as localhost for local development (webhooks will be skipped automatically).
SERVER_URL=http://localhost:3000

# ── Shopify ───────────────────────────────────────────────────────────────────
# Found in your Shopify app → API credentials → API secret key.
# Used to verify HMAC signatures on incoming Shopify webhooks.
SHOPIFY_WEBHOOK_SECRET=

# ── Meta (Facebook/Instagram) ─────────────────────────────────────────────────
# Required only for auto-refreshing long-lived tokens.
# Get from: developers.facebook.com → Your App → Settings → Basic
META_APP_ID=
META_APP_SECRET=

# ── Node environment ──────────────────────────────────────────────────────────
# Set to "development" to enable CORS for local dev (e.g. Live Server on :5500).
# Leave unset or set to "production" when deployed.
NODE_ENV=production
