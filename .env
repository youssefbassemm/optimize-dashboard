# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256 key: 64 hex chars = 32 bytes. Regenerate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit a real key to version control.
ENCRYPTION_KEY=f5a5a19458b8f1a93b7530a2244fcffeb7385d38e486273ccb581ba9bab54186

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./db/optimize.db

# ── Public URL (used to register Shopify webhooks) ────────────────────────────
# Set this to your deployed domain, e.g. https://yourdomain.com
# For local testing, use an SSH tunnel (see README)
SERVER_URL=http://localhost:3000

# ── Shopify webhook signature verification ────────────────────────────────────
# Found in your Shopify custom app → API credentials → API secret key
SHOPIFY_WEBHOOK_SECRET=

# ── Meta (Facebook) App credentials ──────────────────────────────────────────
# Required only for auto-refreshing long-lived tokens (optional but recommended)
# Get from: developers.facebook.com → Your App → Settings → Basic
META_APP_ID=
META_APP_SECRET=
